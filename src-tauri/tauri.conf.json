{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "postchi",
  "version": "0.6.0",
  "identifier": "com.dramaticallyincorrect.postchi",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "title": "postchi",
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 14,
          "y": 24
        },
        "dragDropEnabled": false,
        "backgroundColor": "#111111"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkzMzAwMEQ3NjVDREJCRDQKUldUVXU4MWwxd0F3a3pvdkJBYTV4Znk0bUZtaXR5aGZ1SzFxNkpETk1PWmdzNGhmNXJxL1pFQXgK",
      "endpoints": [
        "https://github.com/dramaticallyincorrect/Postchi/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}